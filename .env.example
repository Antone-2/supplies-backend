# App Configuration
NODE_ENV=production
PORT=5000
LOG_LEVEL=info
MAX_FILE_SIZE=5242880
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15
UPLOAD_PATH=uploads/

# URLs
BACKEND_URL=https://supplies-backend.onrender.com
FRONTEND_URL=https://medhelmsupplies.co.ke
CORS_ORIGINS=https://medhelmsupplies.co.ke

# JWT Secrets - IMPORTANT: Generate new secure secrets
JWT_SECRET=your-secure-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-secure-refresh-secret-min-32-chars
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Session Secret - IMPORTANT: Generate new secure secret
SESSION_SECRET=your-secure-session-secret

# MongoDB - IMPORTANT: Use new credentials
MONGO_URI=mongodb+srv://username:password@cluster.url.mongodb.net/database?retryWrites=true&w=majority

# Redis
REDIS_URL=redis://localhost:6379

# Brevo Email API - IMPORTANT: Get new API key from Brevo dashboard
BREVO_API_KEY=your-brevo-api-key

# Email Configuration
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your-email@domain.com
EMAIL_PASS=your-email-password
EMAIL_FROM=your-email@domain.com

# Cloudinary - IMPORTANT: Get new credentials from Cloudinary dashboard
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name

# Google OAuth - IMPORTANT: Get new credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://supplies-backend.onrender.com/api/v1/auth/google/callback

# Pesapal - IMPORTANT: Get new credentials from Pesapal
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_IPN_URL=https://supplies-backend.onrender.com/api/v1/pesapal/ipn
PESAPAL_CALLBACK_URL=https://supplies-backend.onrender.com/api/v1/pesapal/callback
PESAPAL_CANCEL_URL=https://medhelmsupplies.co.ke/payment-cancel
PESAPAL_REDIRECT_URL=https://medhelmsupplies.co.ke/pesapal/callback
PESAPAL_PRODUCTION_URL=https://www.pesapal.com
PESAPAL_TEST_MODE=false

# Apple OAuth (if applicable)
APPLE_CLIENT_ID=your-apple-client-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key
APPLE_TEAM_ID=your-apple-team-id

# Twilio (if applicable) - IMPORTANT: Get new credentials
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Sentry (if applicable) - IMPORTANT: Get new DSN from Sentry
SENTRY_DSN=your-sentry-dsn

# Security
BCRYPT_ROUNDS=12

# Frontend Variables (for reference)
VITE_API_URL=https://supplies-backend.onrender.com
VITE_BACKEND_URL=https://supplies-backend.onrender.com
VITE_FRONTEND_URL=https://medhelmsupplies.co.ke
VITE_COMPANY_NAME=Medhelm Supplies
VITE_COMPANY_EMAIL=info@medhelmsupplies.co.ke
VITE_COMPANY_PHONE=+254 746 020 323
VITE_SUPPORT_PHONE=+254 746 020 323
VITE_WHATSAPP_NUMBER=254726238126
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
VITE_PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
VITE_PESAPAL_LOGO_BASE=https://pesapal.com/images
VITE_PRIVACY_EMAIL=privacy@medhelmsupplies.co.ke
VITE_RETURNS_EMAIL=returns@medhelmsupplies.co.ke
VITE_SOCIAL_FACEBOOK=https://facebook.com/medhelmsupplies
VITE_SOCIAL_INSTAGRAM=https://instagram.com/medhelmsupplies
VITE_SOCIAL_LINKEDIN=https://linkedin.com/company/medhelmsupplies
VITE_SOCIAL_TWITTER=https://twitter.com/medhelmsupplies
VITE_LOGO_URL=https://medhelmsupplies.co.ke/medhelm-logo.svg
VITE_ENABLE_DEMO_MODE=false
VITE_NODE_ENV=production
